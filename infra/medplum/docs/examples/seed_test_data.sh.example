#!/bin/bash
# Seed a realistic set of test data using a FHIR transaction bundle.
# Creates: 3 patients, a practitioner, org, encounters, observations, conditions, tasks.
# Requires: MEDPLUM_TOKEN

curl -s -X POST http://localhost:8103/fhir/R4 \
  -H "Authorization: Bearer $MEDPLUM_TOKEN" \
  -H "Content-Type: application/fhir+json" \
  -d '{
    "resourceType": "Bundle",
    "type": "transaction",
    "entry": [
      {
        "fullUrl": "urn:uuid:org-1",
        "resource": {
          "resourceType": "Organization",
          "active": true,
          "name": "Medplum Demo Clinic",
          "type": [{ "coding": [{ "system": "http://terminology.hl7.org/CodeSystem/organization-type", "code": "prov" }] }],
          "telecom": [{ "system": "phone", "value": "555-200-3000" }]
        },
        "request": { "method": "POST", "url": "Organization" }
      },
      {
        "fullUrl": "urn:uuid:prac-1",
        "resource": {
          "resourceType": "Practitioner",
          "active": true,
          "name": [{ "use": "official", "family": "Johnson", "given": ["Sarah"], "prefix": ["Dr."] }],
          "gender": "female",
          "telecom": [{ "system": "phone", "value": "555-100-2000", "use": "work" }]
        },
        "request": { "method": "POST", "url": "Practitioner" }
      },
      {
        "fullUrl": "urn:uuid:pat-1",
        "resource": {
          "resourceType": "Patient",
          "active": true,
          "name": [{ "use": "official", "family": "Williams", "given": ["David", "James"] }],
          "gender": "male",
          "birthDate": "1990-02-28",
          "telecom": [
            { "system": "phone", "value": "888-555-8439", "use": "mobile" },
            { "system": "email", "value": "david.williams@example.com" }
          ],
          "address": [{ "use": "home", "line": ["123 Main St"], "city": "San Francisco", "state": "CA", "postalCode": "98732" }]
        },
        "request": { "method": "POST", "url": "Patient" }
      },
      {
        "fullUrl": "urn:uuid:pat-2",
        "resource": {
          "resourceType": "Patient",
          "active": true,
          "name": [{ "use": "official", "family": "California", "given": ["Jane"] }],
          "gender": "female",
          "birthDate": "1978-07-04",
          "telecom": [{ "system": "phone", "value": "555-999-1234", "use": "mobile" }],
          "address": [{ "use": "home", "line": ["456 Oak Ave"], "city": "Los Angeles", "state": "CA", "postalCode": "90001" }]
        },
        "request": { "method": "POST", "url": "Patient" }
      },
      {
        "fullUrl": "urn:uuid:pat-3",
        "resource": {
          "resourceType": "Patient",
          "active": true,
          "name": [{ "use": "official", "family": "Soprano", "given": ["Tony"] }],
          "gender": "male",
          "birthDate": "1959-08-18",
          "telecom": [{ "system": "phone", "value": "201-555-0100", "use": "mobile" }],
          "address": [{ "use": "home", "line": ["633 Stiles Anderson Road"], "city": "North Caldwell", "state": "NJ", "postalCode": "07006" }]
        },
        "request": { "method": "POST", "url": "Patient" }
      },
      {
        "fullUrl": "urn:uuid:cond-1",
        "resource": {
          "resourceType": "Condition",
          "clinicalStatus": { "coding": [{ "system": "http://terminology.hl7.org/CodeSystem/condition-clinical", "code": "active" }] },
          "verificationStatus": { "coding": [{ "system": "http://terminology.hl7.org/CodeSystem/condition-ver-status", "code": "confirmed" }] },
          "category": [{ "coding": [{ "system": "http://terminology.hl7.org/CodeSystem/condition-category", "code": "problem-list-item" }] }],
          "code": { "coding": [{ "system": "http://snomed.info/sct", "code": "714628002", "display": "Prediabetes" }] },
          "subject": { "reference": "urn:uuid:pat-1" },
          "onsetDateTime": "2022-01-01"
        },
        "request": { "method": "POST", "url": "Condition" }
      },
      {
        "fullUrl": "urn:uuid:obs-1",
        "resource": {
          "resourceType": "Observation",
          "status": "final",
          "category": [{ "coding": [{ "system": "http://terminology.hl7.org/CodeSystem/observation-category", "code": "laboratory" }] }],
          "code": { "coding": [{ "system": "http://loinc.org", "code": "35200-5", "display": "Cholesterol" }] },
          "subject": { "reference": "urn:uuid:pat-2" },
          "effectiveDateTime": "2024-03-01T14:26:06Z",
          "valueQuantity": { "value": 6.3, "unit": "mmol/L", "system": "http://unitsofmeasure.org", "code": "mmol/L" },
          "interpretation": [{ "coding": [{ "system": "http://terminology.hl7.org/CodeSystem/v3-ObservationInterpretation", "code": "H", "display": "High" }] }],
          "referenceRange": [{ "high": { "value": 4.5, "unit": "mmol/L" } }]
        },
        "request": { "method": "POST", "url": "Observation" }
      },
      {
        "fullUrl": "urn:uuid:task-1",
        "resource": {
          "resourceType": "Task",
          "status": "ready",
          "intent": "order",
          "priority": "routine",
          "code": { "text": "Review cholesterol results" },
          "for": { "reference": "urn:uuid:pat-2" },
          "focus": { "reference": "urn:uuid:obs-1" },
          "owner": { "reference": "urn:uuid:prac-1" },
          "authoredOn": "2024-03-01T14:30:00Z"
        },
        "request": { "method": "POST", "url": "Task" }
      },
      {
        "fullUrl": "urn:uuid:q-1",
        "resource": {
          "resourceType": "Questionnaire",
          "status": "active",
          "subjectType": ["Patient"],
          "title": "Annual Wellness Check",
          "item": [
            { "linkId": "complaint", "text": "Chief complaint today?", "type": "text" },
            { "linkId": "medications", "text": "Current medications (list)", "type": "text" },
            { "linkId": "allergies", "text": "Any new allergies since last visit?", "type": "boolean" },
            { "linkId": "exercise", "text": "Days of exercise per week", "type": "integer" },
            { "linkId": "smoking", "text": "Smoking status", "type": "choice",
              "answerOption": [
                { "valueCoding": { "code": "never", "display": "Never smoked" } },
                { "valueCoding": { "code": "former", "display": "Former smoker" } },
                { "valueCoding": { "code": "current", "display": "Current smoker" } }
              ]
            }
          ]
        },
        "request": { "method": "POST", "url": "Questionnaire" }
      }
    ]
  }' | python3 -c "
import sys, json
result = json.load(sys.stdin)
print(f'Bundle type: {result.get(\"type\")}')
for entry in result.get('entry', []):
    r = entry.get('resource', {})
    print(f'  {r.get(\"resourceType\")}/{r.get(\"id\")} - {entry.get(\"response\", {}).get(\"status\", \"?\")}')
"
