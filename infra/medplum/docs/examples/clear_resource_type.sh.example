#!/bin/bash
# Delete ALL resources of a given type. Useful for resetting between test runs.
# Requires: MEDPLUM_TOKEN
#
# This script fetches all IDs and deletes them one by one.
# Replace Patient below with any resource type (Encounter, Observation, Task, etc.)
#
# WARNING: This is destructive. Only run against a local/dev instance.

RESOURCE_TYPE="Patient"
BASE_URL="http://localhost:8103"

echo "Fetching all $RESOURCE_TYPE IDs..."

IDS=$(curl -s "$BASE_URL/fhir/R4/$RESOURCE_TYPE?_count=1000&_fields=id" \
  -H "Authorization: Bearer $MEDPLUM_TOKEN" \
  | python3 -c "
import sys, json
bundle = json.load(sys.stdin)
for entry in bundle.get('entry', []):
    print(entry['resource']['id'])
")

COUNT=0
for ID in $IDS; do
  curl -s -X DELETE "$BASE_URL/fhir/R4/$RESOURCE_TYPE/$ID" \
    -H "Authorization: Bearer $MEDPLUM_TOKEN" > /dev/null
  echo "Deleted $RESOURCE_TYPE/$ID"
  COUNT=$((COUNT + 1))
done

echo "Done. Deleted $COUNT $RESOURCE_TYPE resources."
